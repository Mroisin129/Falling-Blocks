<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Falling... Sort Of</title>
<style>
  body {
    background: #111;
    color: white;
    text-align: center;
    font-family: Arial;
  }

  canvas {
    background: #000;
    margin-top: 20px;
    border: 2px solid #444;
  }
</style>
</head>
<body>

<h1>🧱 Just Stack Them...</h1>
<p>Use arrow keys. It should be easy.</p>

<canvas id="game" width="300" height="500"></canvas>

<script>
const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");

const COLS = 10;
const ROWS = 20;
const SIZE = 25;

let piece = createPiece();
let velocity = { x: 0, y: 2 };

// Colors
const colors = ["cyan","yellow","purple","lime","red","blue","orange"];

function createPiece() {
  return {
    x: 4,
    y: 0,
    shape: [[1,1],[1,1]], // simple square
    color: colors[Math.floor(Math.random()*colors.length)],
    vx: (Math.random() - 0.5) * 2,
    vy: 2
  };
}

// Draw
function draw() {
  ctx.clearRect(0,0,canvas.width,canvas.height);

  ctx.fillStyle = piece.color;

  piece.shape.forEach((row, y) => {
    row.forEach((val, x) => {
      if (val) {
        ctx.fillRect(
          (piece.x + x) * SIZE,
          (piece.y + y) * SIZE,
          SIZE-2,
          SIZE-2
        );
      }
    });
  });
}

// Update (THIS is where chaos happens)
function update() {
  piece.x += piece.vx;
  piece.y += piece.vy;

  // Gravity keeps increasing
  piece.vy += 0.15;

  // 😈 Bounce off walls
  if (piece.x < 0 || piece.x > COLS - 2) {
    piece.vx *= -1;
  }

  // 😈 Bounce off floor
  if (piece.y > ROWS - 2) {
    piece.y = ROWS - 2;
    piece.vy *= -0.7;

    // Random horizontal shove
    piece.vx += (Math.random() - 0.5) * 2;
  }

  // 😈 Random drift
  if (Math.random() < 0.02) {
    piece.vx += (Math.random() - 0.5) * 1.5;
  }

  // 😈 Random rotation glitch (visual chaos)
  if (Math.random() < 0.01) {
    piece.shape.reverse();
  }

  // If it “settles”… just spawn another (no stacking!)
  if (Math.abs(piece.vy) < 0.5 && piece.y > ROWS - 3) {
    piece = createPiece();
  }
}

// 😈 Bad controls
document.addEventListener("keydown", e => {
  if (e.key === "ArrowLeft") {
    piece.vx -= 1.5; // too strong
  }
  if (e.key === "ArrowRight") {
    piece.vx += 1.5;
  }
  if (e.key === "ArrowDown") {
    piece.vy += 2; // makes it worse
  }
  if (e.key === "ArrowUp") {
    // random rotation instead of real
    if (Math.random() < 0.5) {
      piece.shape.reverse();
    }
  }
});

// Game loop
function loop() {
  update();
  draw();
  requestAnimationFrame(loop);
}

loop();
</script>

</body>
</html>
